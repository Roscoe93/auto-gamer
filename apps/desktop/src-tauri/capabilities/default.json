{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "KuroNeko Studio desktop default capability.",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "shell:allow-kill",
    {
      "identifier": "shell:allow-execute",
      "allow": [
        {
          "name": "kuroneko-studio-bridge",
          "sidecar": true
        }
      ]
    }
  ]
}
