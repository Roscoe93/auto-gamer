{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Quiet Studio",
  "version": "0.1.0",
  "identifier": "com.quietstudio.desktop",
  "build": {
    "beforeDevCommand": "",
    "frontendDist": "../dist",
    "devUrl": "http://127.0.0.1:1420"
  },
  "app": {
    "windows": [
      {
        "title": "Quiet Studio",
        "width": 1440,
        "height": 960,
        "resizable": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "externalBin": ["binaries/quiet-studio-bridge"]
  }
}
