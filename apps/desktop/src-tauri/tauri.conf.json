{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "KuroNeko Studio",
  "version": "0.1.0",
  "identifier": "com.kuronekostudio.desktop",
  "build": {
    "beforeDevCommand": "",
    "frontendDist": "../dist",
    "devUrl": "http://127.0.0.1:1420"
  },
  "app": {
    "windows": [
      {
        "title": "KuroNeko Studio",
        "width": 1440,
        "height": 960,
        "resizable": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": ["binaries/kuroneko-studio-bridge"]
  }
}
